# AJAZZ AK820 Macro Pad — udev rules
# Triggers systemd USER service (required for GUI commands like xterm, xdg-open)

ACTION=="add", SUBSYSTEM=="usb", \
  ATTRS{idVendor}=="0300", ATTRS{idProduct}=="3010", \
  TAG+="systemd", ENV{SYSTEMD_USER_WANTS}="ajazz-deck.service"

ACTION=="remove", SUBSYSTEM=="usb", \
  ENV{ID_VENDOR_ID}=="0300", ENV{ID_MODEL_ID}=="3010", \
  TAG+="systemd", ENV{SYSTEMD_USER_WANTS}="ajazz-deck-stop.service"
